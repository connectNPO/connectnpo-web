# Supabase (ConnectNPO 프로젝트 재사용 - quiz_leads 테이블 추가 필요)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-NOT-anon-key

# Google Workspace SMTP
# 1. quiz@givingarc.com 계정에 2FA 활성화
# 2. https://myaccount.google.com/apppasswords 에서 16자리 App Password 발급
GMAIL_USER=quiz@givingarc.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
FROM_NAME=GivingArc

# 컨설팅 예약 링크 (Cal.com, Calendly 등)
CONSULTATION_URL=https://cal.com/givingarc/intro
